# RisingWave Cloud (PostgreSQL-compatible)
RW_HOST=your-risingwave-host.risingwave.cloud
RW_PORT=4566
RW_USER=root
RW_PASSWORD=your-password
RW_DATABASE=dev

# OpenRouter API
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=minimax/minimax-m2.5:free

# Demo settings
GENERATOR_SPEED=1.0
NUM_TRUCKS=10
NUM_WAREHOUSES=3
