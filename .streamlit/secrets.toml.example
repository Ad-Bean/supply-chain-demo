# Streamlit Cloud secrets — paste into Settings > Secrets on streamlit.io
# These override .env when deployed to Streamlit Cloud.

RW_HOST = "your-risingwave-host.risingwave.cloud"
RW_PORT = "4566"
RW_USER = "your-user"
RW_PASSWORD = "your-password"
RW_DATABASE = "dev"
RW_SSLMODE = "require"

OPENROUTER_API_KEY = "sk-or-v1-your-key"
OPENROUTER_MODEL = "minimax/minimax-m2.5:free"
